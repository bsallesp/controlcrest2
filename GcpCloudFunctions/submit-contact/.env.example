# Origens permitidas (CORS), separadas por vírgula, ou * 
ALLOWED_ORIGIN=https://seu-bucket-site.web.app,https://controlcrest.com

# --- Gmail (Google Workspace) — conta de serviço com delegação em domínio (admin.google.com)
# JSON completo da chave (uma linha ou use Secret Manager no deploy)
GMAIL_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"submit-leads@proj.iam.gserviceaccount.com",...}
# Usuário Workspace a impersonar (enviar como)
GMAIL_SEND_AS_USER=leads@seudominio.com
MAIL_TO_ADDRESS=recepcao@seudominio.com

# --- Telnyx — SMS (fallback após Gmail; mesmo padrão do ControlCrest_OLD: Bearer + /v2/messages)
TELNYX_API_KEY=KEY019...
TELNYX_FROM_NUMBER=+1XXXXXXXXXX
TELNYX_TO_NUMBER=+1XXXXXXXXXX

# --- Google Chat — último fallback (se Gmail e Telnyx falharem ou só Chat configurado)
# Espaço do Chat → Configurações → Integrações e apps → Webhooks de entrada
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/.../messages?key=...
