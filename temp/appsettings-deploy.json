{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "acsConnectionString": { "type": "securestring" },
    "mailFrom":            { "type": "string" },
    "mailTo":              { "type": "string" },
    "allowedOrigin":       { "type": "string" }
  },
  "resources": [
    {
      "type": "Microsoft.Web/sites/config",
      "apiVersion": "2022-09-01",
      "name": "func-cc-controlcrest/appsettings",
      "properties": {
        "ACS_CONNECTION_STRING":   "[parameters('acsConnectionString')]",
        "MAIL_FROM_ADDRESS":       "[parameters('mailFrom')]",
        "MAIL_TO_ADDRESS":         "[parameters('mailTo')]",
        "ALLOWED_ORIGIN":          "[parameters('allowedOrigin')]",
        "FUNCTIONS_WORKER_RUNTIME":"node",
        "WEBSITE_NODE_DEFAULT_VERSION": "~20"
      }
    }
  ]
}
